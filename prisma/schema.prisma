generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobOpportunityStatus {
  DISCOVERED
  SAVED
  APPLIED
  CLOSED
  ARCHIVED
}

enum WorkArrangement {
  ONSITE
  HYBRID
  REMOTE
  FLEXIBLE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  INTERNSHIP
  FREELANCE
  OTHER
}

enum ApplicationStatus {
  DRAFT
  APPLIED
  IN_PROGRESS
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
  ARCHIVED
}

enum ApplicationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityType {
  SUBMITTED
  CONTACT_FOUND
  LINKEDIN_REQUEST
  LINKEDIN_MESSAGE
  LINKEDIN_RESPONSE
  EMAIL_SENT
  EMAIL_RESPONSE
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  FOLLOW_UP
  NOTE
  REJECTION
  OFFER
  DOCUMENT_GENERATED
  STATUS_CHANGE
  OTHER
}

enum EmailConfidence {
  UNKNOWN
  LOW
  MEDIUM
  HIGH
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  RESCHEDULED
  NO_SHOW
}

enum DocumentType {
  RESUME
  COVER_LETTER
  APPLICATION_ANSWER
  INTERVIEW_PREP
  PORTFOLIO
  OTHER
}

enum DocumentStatus {
  DRAFT
  REVIEWED
  DOWNLOADED
  SUBMITTED
  SUPERSEDED
  ARCHIVED
}

enum DocumentFormat {
  PDF
  DOCX
  TXT
  MD
  JSON
  OTHER
}

enum DocumentSource {
  UPLOADED
  GENERATED
  IMPORTED
  OTHER
}

enum CareerProfilePurpose {
  USER
  FIXTURE
}

enum DocumentRenderStatus {
  PENDING
  SUCCESS
  SUCCESS_WITH_WARNINGS
  FAILED
}

enum JobDescriptionSourceType {
  MANUAL_PASTE
  LINKEDIN
  COMPANY_SITE
  RECRUITER
  EMAIL
  JOB_BOARD
  IMPORTED_FILE
  OTHER
}

enum JobDescriptionParseStatus {
  PENDING
  SUCCESS
  SUCCESS_WITH_WARNINGS
  FAILED
}

enum JobRequirementAnalysisStatus {
  DRAFT
  NEEDS_REVIEW
  CONFIRMED
  SUPERSEDED
  FAILED
}

enum EvidenceRetrievalRunStatus {
  PENDING
  SUCCESS
  SUCCESS_WITH_WARNINGS
  FAILED
}

enum EvidenceScoringRunStatus {
  PENDING
  SUCCESS
  SUCCESS_WITH_WARNINGS
  FAILED
}

enum MatchReportRunStatus {
  PENDING
  SUCCESS
  SUCCESS_WITH_WARNINGS
  FAILED
}

enum CoverLetterCompositionVersionStatus {
  PENDING
  SUCCESS
  SUCCESS_WITH_WARNINGS
  FAILED
}

enum CoverLetterRevisionVersionStatus {
  DRAFT
  FINALIZED
  SUPERSEDED
  FAILED
}

enum CoverLetterAuditRunStatus {
  PENDING
  SUCCESS
  SUCCESS_WITH_WARNINGS
  FAILED
}

enum CoverLetterApprovalStatus {
  APPROVED
  REVOKED
  SUPERSEDED
}

enum CoverLetterSourceType {
  BASE_COMPOSITION
  FINALIZED_REVISION
}

enum StructuredResumeVersionStatus {
  PENDING
  READY
  READY_WITH_LIMITATIONS
  NEEDS_REVIEW
  FAILED
  SUPERSEDED
}

enum ResumeCompositionVersionStatus {
  PENDING
  READY
  READY_WITH_WARNINGS
  NEEDS_REVIEW
  FAILED
  SUPERSEDED
}

enum ResumeAuditRunStatus {
  PENDING
  PASSED
  PASSED_WITH_WARNINGS
  FAILED
  NEEDS_REVIEW
}

enum ResumeRevisionVersionStatus {
  DRAFT
  READY_FOR_AUDIT
  AUDITED
  NEEDS_REVIEW
  SUPERSEDED
  FAILED
}

enum ResumeRenderingApprovalStatus {
  APPROVED
  REVOKED
  SUPERSEDED
}

enum ResumeRenderingSourceType {
  BASE_COMPOSITION
  FINALIZED_REVISION
}

enum ResumeRenderingArtifactType {
  RESUME
}

enum ResumeRenderingApproverType {
  WORKSPACE_OWNER
}

enum ImportJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum ImportRowStatus {
  PENDING
  PREVIEW
  READY
  IMPORTED
  DUPLICATE
  INVALID
  SKIPPED
}

enum AiRunPurpose {
  PARSE_JOB_DESCRIPTION
  SCORE_CAREER_EVIDENCE
  GENERATE_RESUME_CONTENT
  GENERATE_COVER_LETTER
  GENERATE_APPLICATION_ANSWER
  GENERATE_INTERVIEW_PREPARATION
}

enum AiRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

model Workspace {
  id                    String                    @id @default(cuid())
  name                  String
  currentCareerProfileVersionId String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  activities            Activity[]
  aiRuns                AiRun[]
  applications          Application[]
  auditEvents           AuditEvent[]
  careerProfileSources  CareerProfileSource[]
  careerProfileVersions CareerProfileVersion[]
  currentCareerProfileVersion CareerProfileVersion? @relation("WorkspaceCurrentCareerProfileVersion", fields: [currentCareerProfileVersionId], references: [id], onDelete: SetNull)
  companies             Company[]
  coverLetterCompositionVersions CoverLetterCompositionVersion[]
  coverLetterRevisionVersions CoverLetterRevisionVersion[]
  coverLetterAuditRuns  CoverLetterAuditRun[]
  coverLetterApprovals  CoverLetterApproval[]
  contacts              Contact[]
  documents             Document[]
  documentVersions      DocumentVersion[]
  matchReportRuns       MatchReportRun[]
  resumeAuditRuns       ResumeAuditRun[]
  resumeCompositionVersions ResumeCompositionVersion[]
  resumeRenderingApprovals ResumeRenderingApproval[]
  resumeRevisionVersions ResumeRevisionVersion[]
  structuredResumeVersions StructuredResumeVersion[]
  evidenceScoringRuns   EvidenceScoringRun[]
  evidenceRetrievalRuns EvidenceRetrievalRun[]
  importJobs            ImportJob[]
  interviews            Interview[]
  jobDescriptionParses  JobDescriptionParse[]
  jobRequirementAnalyses JobRequirementAnalysis[]
  jobDescriptionVersions JobDescriptionVersion[]
  jobOpportunities      JobOpportunity[]
  userSettings          UserSetting[]
}

model Company {
  id               String           @id @default(cuid())
  workspaceId      String
  name             String
  normalizedName   String
  website          String?
  linkedinUrl      String?
  industry         String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  activities       Activity[]
  contacts         Contact[]
  jobOpportunities JobOpportunity[]

  @@unique([workspaceId, normalizedName])
  @@index([workspaceId, name])
}

model JobOpportunity {
  id              String               @id @default(cuid())
  workspaceId     String
  companyId       String
  title           String
  jobUrl          String?
  source          String?
  location        String?
  workArrangement WorkArrangement?
  employmentType  EmploymentType?
  salaryMin       Decimal?             @db.Decimal(12, 2)
  salaryMax       Decimal?             @db.Decimal(12, 2)
  salaryCurrency  String?
  descriptionText String?
  descriptionData Json?
  postedAt        DateTime?
  capturedAt      DateTime             @default(now())
  status          JobOpportunityStatus @default(DISCOVERED)
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  coverLetterApprovals CoverLetterApproval[]
  coverLetterAuditRuns CoverLetterAuditRun[]
  coverLetterCompositionVersions CoverLetterCompositionVersion[]
  coverLetterRevisionVersions CoverLetterRevisionVersion[]
  jobDescriptionVersions JobDescriptionVersion[]
  workspace       Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  applications    Application[]

  @@index([workspaceId, status])
  @@index([companyId])
}

model Application {
  id                    String                     @id @default(cuid())
  workspaceId           String
  opportunityId         String
  currentJobDescriptionVersionId String?
  appliedAt             DateTime?
  recordedAt            DateTime                   @default(now())
  originalAppliedAt     DateTime?
  jobSearchDate         DateTime?                  @db.Date
  status                ApplicationStatus          @default(DRAFT)
  priority              ApplicationPriority?
  notes                 String?
  archivedAt            DateTime?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  workspace             Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  opportunity           JobOpportunity             @relation(fields: [opportunityId], references: [id], onDelete: Restrict)
  activities            Activity[]                 @relation("ApplicationActivities")
  aiRuns                AiRun[]                    @relation("ApplicationAiRuns")
  coverLetterApprovals  CoverLetterApproval[]
  coverLetterAuditRuns  CoverLetterAuditRun[]
  coverLetterCompositionVersions CoverLetterCompositionVersion[]
  coverLetterRevisionVersions CoverLetterRevisionVersion[]
  currentJobDescriptionVersion JobDescriptionVersion? @relation("ApplicationCurrentJobDescription", fields: [currentJobDescriptionVersionId], references: [id], onDelete: SetNull)
  capturedJobDescriptions JobDescriptionVersion[]  @relation("JobDescriptionSourceApplication")
  documents             Document[]                 @relation("ApplicationDocuments")
  documentVersions      DocumentVersion[]          @relation("ApplicationDocumentVersions")
  interviews            Interview[]
  matchedImportRows     ImportRow[]                @relation("MatchedImportRows")
  statusHistoryEntries  ApplicationStatusHistory[]
  evidenceRetrievalRuns EvidenceRetrievalRun[]
  evidenceScoringRuns   EvidenceScoringRun[]
  matchReportRuns       MatchReportRun[]
  resumeAuditRuns       ResumeAuditRun[]
  resumeCompositionVersions ResumeCompositionVersion[]
  resumeRenderingApprovals ResumeRenderingApproval[]
  resumeRevisionVersions ResumeRevisionVersion[]
  structuredResumeVersions StructuredResumeVersion[]

  @@index([workspaceId, status, jobSearchDate])
  @@index([currentJobDescriptionVersionId])
  @@index([opportunityId])
}

model JobDescriptionVersion {
  id                 String                 @id @default(cuid())
  workspaceId        String
  opportunityId      String
  sourceApplicationId String?
  predecessorId      String?
  versionNumber      Int
  originalText       String
  normalizedText     String
  sourceUrl          String?
  sourceType         JobDescriptionSourceType
  sourceTitle        String?
  sourceFilename     String?
  capturedAt         DateTime               @default(now())
  publishedAt        DateTime?              @db.Date
  checksum           String
  formatVersion      String
  createdByWorkflow  String
  provenance         Json?
  active             Boolean                @default(false)
  supersededAt       DateTime?
  createdAt          DateTime               @default(now())
  sourceApplication  Application?           @relation("JobDescriptionSourceApplication", fields: [sourceApplicationId], references: [id], onDelete: SetNull)
  currentForApplications Application[]      @relation("ApplicationCurrentJobDescription")
  parses             JobDescriptionParse[]
  requirementAnalyses JobRequirementAnalysis[]
  evidenceRetrievalRuns EvidenceRetrievalRun[]
  evidenceScoringRuns   EvidenceScoringRun[]
  matchReportRuns       MatchReportRun[]
  coverLetterApprovals  CoverLetterApproval[]
  coverLetterAuditRuns  CoverLetterAuditRun[]
  coverLetterCompositionVersions CoverLetterCompositionVersion[]
  coverLetterRevisionVersions CoverLetterRevisionVersion[]
  resumeAuditRuns       ResumeAuditRun[]
  resumeCompositionVersions ResumeCompositionVersion[]
  documents           Document[]
  documentVersions    DocumentVersion[]
  resumeRenderingApprovals ResumeRenderingApproval[]
  resumeRevisionVersions ResumeRevisionVersion[]
  structuredResumeVersions StructuredResumeVersion[]
  opportunity        JobOpportunity         @relation(fields: [opportunityId], references: [id], onDelete: Restrict)
  predecessor        JobDescriptionVersion? @relation("JobDescriptionVersionPredecessor", fields: [predecessorId], references: [id], onDelete: SetNull)
  successors         JobDescriptionVersion[] @relation("JobDescriptionVersionPredecessor")
  workspace          Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Restrict)

  @@unique([opportunityId, versionNumber])
  @@unique([opportunityId, checksum])
  @@index([workspaceId, opportunityId, active, createdAt])
  @@index([sourceApplicationId, createdAt])
}

model JobDescriptionParse {
  id                    String                    @id @default(cuid())
  workspaceId           String
  jobDescriptionVersionId String
  parserVersion         String
  contractVersion       String
  sourceChecksum        String
  status                JobDescriptionParseStatus @default(PENDING)
  diagnostics           Json
  result                Json?
  createdByWorkflow     String
  errorSummary          String?
  createdAt             DateTime                  @default(now())
  completedAt           DateTime?
  jobDescriptionVersion JobDescriptionVersion     @relation(fields: [jobDescriptionVersionId], references: [id], onDelete: Restrict)
  requirementAnalyses   JobRequirementAnalysis[]
  workspace             Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Restrict)

  @@index([workspaceId, createdAt])
  @@index([jobDescriptionVersionId, createdAt])
  @@index([jobDescriptionVersionId, parserVersion, status, createdAt])
}

model JobRequirementAnalysis {
  id                    String                       @id @default(cuid())
  workspaceId           String
  jobDescriptionVersionId String
  jobDescriptionParseId String
  predecessorId         String?
  contractVersion       String
  classifierVersion     String
  sourceChecksum        String
  parserVersion         String
  status                JobRequirementAnalysisStatus @default(DRAFT)
  analysis              Json
  diagnostics           Json
  createdByWorkflow     String
  acknowledgement       Json?
  errorSummary          String?
  createdAt             DateTime                     @default(now())
  confirmedAt           DateTime?
  supersededAt          DateTime?
  predecessor           JobRequirementAnalysis?      @relation("JobRequirementAnalysisPredecessor", fields: [predecessorId], references: [id], onDelete: SetNull)
  successors            JobRequirementAnalysis[]     @relation("JobRequirementAnalysisPredecessor")
  jobDescriptionParse   JobDescriptionParse          @relation(fields: [jobDescriptionParseId], references: [id], onDelete: Restrict)
  jobDescriptionVersion JobDescriptionVersion        @relation(fields: [jobDescriptionVersionId], references: [id], onDelete: Restrict)
  workspace             Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  evidenceRetrievalRuns EvidenceRetrievalRun[]
  evidenceScoringRuns   EvidenceScoringRun[]
  matchReportRuns       MatchReportRun[]
  coverLetterCompositionVersions CoverLetterCompositionVersion[]
  coverLetterRevisionVersions CoverLetterRevisionVersion[]
  coverLetterAuditRuns  CoverLetterAuditRun[]
  resumeAuditRuns       ResumeAuditRun[]
  resumeCompositionVersions ResumeCompositionVersion[]
  resumeRenderingApprovals ResumeRenderingApproval[]
  resumeRevisionVersions ResumeRevisionVersion[]
  structuredResumeVersions StructuredResumeVersion[]

  @@index([workspaceId, createdAt])
  @@index([jobDescriptionVersionId, createdAt])
  @@index([jobDescriptionParseId, classifierVersion, status, createdAt])
}

model ApplicationStatusHistory {
  id            String             @id @default(cuid())
  applicationId String
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  occurredAt    DateTime
  recordedAt    DateTime           @default(now())
  reason        String?
  source        String?
  application   Application        @relation(fields: [applicationId], references: [id], onDelete: Restrict)

  @@index([applicationId, occurredAt])
}

model Activity {
  id               String        @id @default(cuid())
  workspaceId      String
  applicationId    String?
  companyId        String?
  contactId        String?
  interviewId      String?
  type             ActivityType
  occurredAt       DateTime
  originalOccurredAt DateTime?
  recordedAt       DateTime      @default(now())
  jobSearchDate    DateTime      @db.Date
  timeZone         String?
  summary          String
  notes            String?
  metadata         Json?
  createdAt        DateTime      @default(now())
  application      Application?  @relation("ApplicationActivities", fields: [applicationId], references: [id], onDelete: SetNull)
  company          Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact          Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  interview        Interview?    @relation(fields: [interviewId], references: [id], onDelete: SetNull)
  workspace        Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Restrict)

  @@index([workspaceId, jobSearchDate])
  @@index([applicationId, occurredAt])
}

model Contact {
  id                String          @id @default(cuid())
  workspaceId       String
  companyId         String?
  name              String
  title             String?
  linkedinUrl       String?
  email             String?
  emailConfidence   EmailConfidence @default(UNKNOWN)
  relationshipType  String?
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  company           Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  activities        Activity[]

  @@index([workspaceId, name])
  @@index([companyId])
}

model Interview {
  id                  String          @id @default(cuid())
  workspaceId         String
  applicationId       String
  stage               String
  scheduledStart      DateTime
  scheduledEnd        DateTime?
  timeZone            String
  locationOrMeetingUrl String?
  status              InterviewStatus @default(SCHEDULED)
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  application         Application     @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  workspace           Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  activities          Activity[]

  @@index([workspaceId, scheduledStart])
  @@index([applicationId, scheduledStart])
}

model Document {
  id            String         @id @default(cuid())
  workspaceId   String
  applicationId String?
  jobDescriptionVersionId String?
  type          DocumentType
  title         String
  status        DocumentStatus @default(DRAFT)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  application   Application?   @relation("ApplicationDocuments", fields: [applicationId], references: [id], onDelete: SetNull)
  jobDescriptionVersion JobDescriptionVersion? @relation(fields: [jobDescriptionVersionId], references: [id], onDelete: SetNull)
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  versions      DocumentVersion[]

  @@index([applicationId, createdAt])
  @@index([jobDescriptionVersionId, createdAt])
  @@index([workspaceId, type])
}

model DocumentVersion {
  id               String         @id @default(cuid())
  documentId       String
  workspaceId      String
  applicationId    String?
  jobDescriptionVersionId String
  resumeRenderingApprovalId String?
  resumeAuditRunId String?
  resumeCompositionVersionId String?
  resumeRevisionVersionId String?
  coverLetterApprovalId String?
  coverLetterAuditRunId String?
  coverLetterCompositionVersionId String?
  coverLetterRevisionVersionId String?
  versionNumber    Int
  format           DocumentFormat
  originalFilename String
  storedFilename   String
  storagePath      String
  mimeType         String
  sizeBytes        Int
  checksum         String
  source           DocumentSource
  renderStatus     DocumentRenderStatus @default(PENDING)
  renderContractVersion String
  rendererVersion  String
  templateVersion  String
  configurationVersion String
  renderInputChecksum String
  warningCount     Int            @default(0)
  validationSummary Json?
  errorSummary     String?
  generatedAt      DateTime       @default(now())
  downloadedAt     DateTime?
  submittedAt      DateTime?
  metadata         Json?
  application      Application?   @relation("ApplicationDocumentVersions", fields: [applicationId], references: [id], onDelete: SetNull)
  document         Document       @relation(fields: [documentId], references: [id], onDelete: Restrict)
  jobDescriptionVersion JobDescriptionVersion @relation(fields: [jobDescriptionVersionId], references: [id], onDelete: Restrict)
  resumeAuditRun   ResumeAuditRun? @relation(fields: [resumeAuditRunId], references: [id], onDelete: Restrict)
  resumeCompositionVersion ResumeCompositionVersion? @relation(fields: [resumeCompositionVersionId], references: [id], onDelete: Restrict)
  resumeRenderingApproval ResumeRenderingApproval? @relation(fields: [resumeRenderingApprovalId], references: [id], onDelete: Restrict)
  resumeRevisionVersion ResumeRevisionVersion? @relation(fields: [resumeRevisionVersionId], references: [id], onDelete: SetNull)
  coverLetterApproval CoverLetterApproval? @relation(fields: [coverLetterApprovalId], references: [id], onDelete: Restrict)
  coverLetterAuditRun CoverLetterAuditRun? @relation(fields: [coverLetterAuditRunId], references: [id], onDelete: Restrict)
  coverLetterCompositionVersion CoverLetterCompositionVersion? @relation(fields: [coverLetterCompositionVersionId], references: [id], onDelete: Restrict)
  coverLetterRevisionVersion CoverLetterRevisionVersion? @relation(fields: [coverLetterRevisionVersionId], references: [id], onDelete: SetNull)
  workspace        Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Restrict)

  @@unique([documentId, versionNumber])
  @@index([documentId, generatedAt])
  @@index([workspaceId, generatedAt])
  @@index([applicationId, generatedAt])
  @@index([jobDescriptionVersionId, generatedAt])
  @@index([resumeRenderingApprovalId, generatedAt])
  @@index([resumeAuditRunId, generatedAt])
  @@index([resumeCompositionVersionId, generatedAt])
  @@index([resumeRevisionVersionId, generatedAt])
  @@index([coverLetterApprovalId, generatedAt])
  @@index([coverLetterAuditRunId, generatedAt])
  @@index([coverLetterCompositionVersionId, generatedAt])
  @@index([coverLetterRevisionVersionId, generatedAt])
  @@index([workspaceId, renderInputChecksum, renderStatus, generatedAt])
}

model ImportJob {
  id           String          @id @default(cuid())
  workspaceId  String
  filename     String
  checksum     String
  status       ImportJobStatus @default(PENDING)
  startedAt    DateTime        @default(now())
  completedAt  DateTime?
  sheetName    String?
  mapping      Json?
  summary      Json?
  errorMessage String?
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  rows         ImportRow[]

  @@index([workspaceId, status, startedAt])
}

model ImportRow {
  id                   String         @id @default(cuid())
  importJobId          String
  sheetName            String
  rowNumber            Int
  rawData              Json
  normalizedData       Json?
  status               ImportRowStatus @default(PENDING)
  errorMessages        Json?
  matchedApplicationId String?
  importJob            ImportJob      @relation(fields: [importJobId], references: [id], onDelete: Restrict)
  matchedApplication   Application?   @relation("MatchedImportRows", fields: [matchedApplicationId], references: [id], onDelete: SetNull)

  @@index([importJobId, status])
  @@index([matchedApplicationId])
}

model UserSetting {
  id          String    @id @default(cuid())
  workspaceId String
  key         String
  value       Json
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)

  @@unique([workspaceId, key])
}

model AuditEvent {
  id         String    @id @default(cuid())
  workspaceId String
  entityType String
  entityId   String
  action     String
  occurredAt DateTime  @default(now())
  before     Json?
  after      Json?
  reason     String?
  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)

  @@index([workspaceId, occurredAt])
  @@index([entityType, entityId])
}

model CareerProfileVersion {
  id                String                @id @default(cuid())
  workspaceId       String
  sourceId          String
  predecessorId     String?
  schemaVersion     String
  importerVersion   String
  sourceFilename    String
  sourceVersion     String?
  content           Json
  validationSummary Json
  checksum          String
  importedAt        DateTime              @default(now())
  supersededAt      DateTime?
  active            Boolean               @default(false)
  predecessor       CareerProfileVersion? @relation("CareerProfileVersionPredecessor", fields: [predecessorId], references: [id], onDelete: SetNull)
  source            CareerProfileSource   @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  successors        CareerProfileVersion[] @relation("CareerProfileVersionPredecessor")
  currentForWorkspaces Workspace[]        @relation("WorkspaceCurrentCareerProfileVersion")
  workspace         Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  coverLetterCompositionVersions CoverLetterCompositionVersion[]
  coverLetterRevisionVersions CoverLetterRevisionVersion[]
  coverLetterAuditRuns  CoverLetterAuditRun[]
  evidenceRetrievalRuns EvidenceRetrievalRun[]
  evidenceScoringRuns   EvidenceScoringRun[]
  matchReportRuns       MatchReportRun[]
  resumeAuditRuns       ResumeAuditRun[]
  resumeCompositionVersions ResumeCompositionVersion[]
  resumeRenderingApprovals ResumeRenderingApproval[]
  resumeRevisionVersions ResumeRevisionVersion[]
  structuredResumeVersions StructuredResumeVersion[]

  @@unique([sourceId, schemaVersion, importerVersion])
  @@index([workspaceId, active, importedAt])
}

model EvidenceRetrievalRun {
  id                     String                     @id @default(cuid())
  workspaceId            String
  careerProfileVersionId String
  requirementAnalysisId  String
  jobDescriptionVersionId String
  applicationId          String?
  contractVersion        String
  engineVersion          String
  careerSourceChecksum   String
  requirementSourceChecksum String
  inputChecksum          String
  status                 EvidenceRetrievalRunStatus @default(PENDING)
  result                 Json?
  summary                Json?
  diagnostics            Json?
  errorSummary           String?
  createdAt              DateTime                   @default(now())
  completedAt            DateTime?
  application            Application?               @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  careerProfileVersion   CareerProfileVersion       @relation(fields: [careerProfileVersionId], references: [id], onDelete: Restrict)
  jobDescriptionVersion  JobDescriptionVersion      @relation(fields: [jobDescriptionVersionId], references: [id], onDelete: Restrict)
  requirementAnalysis    JobRequirementAnalysis     @relation(fields: [requirementAnalysisId], references: [id], onDelete: Restrict)
  workspace              Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  coverLetterCompositionVersions CoverLetterCompositionVersion[]
  coverLetterRevisionVersions CoverLetterRevisionVersion[]
  coverLetterAuditRuns  CoverLetterAuditRun[]
  scoringRuns            EvidenceScoringRun[]

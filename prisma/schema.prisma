  matchReportRun             MatchReportRun                @relation(fields: [matchReportRunId], references: [id], onDelete: Restrict)
  predecessorApproval        ResumeRenderingApproval?      @relation("ResumeRenderingApprovalPredecessor", fields: [predecessorApprovalId], references: [id], onDelete: SetNull)
  requirementAnalysis        JobRequirementAnalysis        @relation(fields: [requirementAnalysisId], references: [id], onDelete: Restrict)
  documentVersions           DocumentVersion[]
  resumeAuditRun             ResumeAuditRun                @relation(fields: [resumeAuditRunId], references: [id], onDelete: Restrict)
  resumeCompositionVersion   ResumeCompositionVersion?     @relation(fields: [resumeCompositionVersionId], references: [id], onDelete: SetNull)
  resumeRevisionVersion      ResumeRevisionVersion?        @relation(fields: [resumeRevisionVersionId], references: [id], onDelete: SetNull)
  structuredResumeVersion    StructuredResumeVersion       @relation(fields: [structuredResumeVersionId], references: [id], onDelete: Restrict)
  successorApprovals         ResumeRenderingApproval[]     @relation("ResumeRenderingApprovalPredecessor")
  workspace                  Workspace                     @relation(fields: [workspaceId], references: [id], onDelete: Restrict)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, jobDescriptionVersionId, createdAt], map: "ResumeRenderingApproval_workspace_jobdesc_created_idx")
  @@index([applicationId, createdAt])
  @@index([resumeAuditRunId, createdAt])
  @@index([resumeCompositionVersionId, createdAt])
  @@index([resumeRevisionVersionId, createdAt])
  @@index([predecessorApprovalId, createdAt])
  @@index([workspaceId, jobDescriptionVersionId, resumeArtifactType, status, createdAt], map: "ResumeRenderingApproval_ws_job_artifact_status_idx")
  @@index([workspaceId, contentChecksum, resumeAuditRunId, status, createdAt])
}

model CareerProfileSource {
  id         String                 @id @default(cuid())
  workspaceId String
  filename   String
  fileType   String
  mimeType   String
  sizeBytes  Int
  checksum   String
  purpose    CareerProfilePurpose   @default(USER)
  sourceVersion String?
  rawPayload Json
  createdAt  DateTime               @default(now())
  versions   CareerProfileVersion[]
  workspace  Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Restrict)

  @@unique([workspaceId, checksum])
  @@index([workspaceId, createdAt])
}

model AiRun {
  id               String       @id @default(cuid())
  workspaceId      String
  applicationId    String?
  purpose          AiRunPurpose
  provider         String
  model            String
  promptVersion    String?
  request          Json?
  response         Json?
  structuredResult Json?
  status           AiRunStatus  @default(PENDING)
  tokenUsage       Json?
  startedAt        DateTime     @default(now())
  completedAt      DateTime?
  errorMessage     String?
  application      Application? @relation("ApplicationAiRuns", fields: [applicationId], references: [id], onDelete: SetNull)
  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Restrict)

  @@index([workspaceId, status, startedAt])
  @@index([applicationId, purpose])
}
